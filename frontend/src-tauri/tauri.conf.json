{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "丸子配音",
  "version": "0.1.0",
  "identifier": "com.maruaudio.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "丸子配音",
        "width": 1440,
        "height": 900,
        "decorations": false,
        "center": true,
        "resizable": false,
        "minWidth": 1024,
        "minHeight": 700,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://auth.wzagent.cn data:; connect-src 'self' https://auth.wzagent.cn wss://auth.wzagent.cn; font-src 'self' data:; media-src 'self' blob:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
