RewriteEngine On
RewriteBase /api/

# 如果请求的是真实文件或目录，直接访问
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 其他所有请求重定向到 index.php
RewriteRule ^(.*)$ index.php [QSA,L]

# 安全设置
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止访问配置文件
<FilesMatch "\.(php|ini|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# 允许访问 index.php
<Files "index.php">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>
