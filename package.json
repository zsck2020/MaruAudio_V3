{
  "name": "maruaudio-v3",
  "version": "0.1.0",
  "description": "丸子配音桌面端",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,desktop --restart-tries 3 --restart-after 2000 \"npm:dev:web\" \"npm:dev:desktop\"",
    "dev:web": "vite dev --port 1420 --strictPort --host",
    "dev:desktop": "wait-on http://localhost:1420 && tauri dev",
    "dev:web-only": "vite dev --port 1420 --strictPort --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "svelte-carousel": "^1.0.25"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.3",
    "@tauri-apps/cli": "^2"
  }
}
