{
  "name": "maruaudio-v3",
  "version": "0.1.0",
  "description": "丸子配音桌面端",
  "type": "module",
  "scripts": {
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/kill-dev.ps1",
    "predev": "npm run clean",
    "dev": "concurrently -n frontend,desktop --restart-tries 3 --restart-after 2000 \"npm:dev:frontend\" \"npm:dev:desktop\"",
    "dev:frontend": "vite dev --port 1420 --strictPort --host localhost",
    "dev:desktop": "wait-on http://localhost:1420 && tauri dev",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify/svelte": "^5.2.1",
    "@lobehub/webfont-harmony-sans-sc": "^1.0.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "svelte-carousel": "^1.0.25"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.1.2",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.3"
  }
}
