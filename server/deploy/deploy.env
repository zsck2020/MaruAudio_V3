# MaruAudio 部署环境变量
# 迁移服务器时只需修改此文件，然后运行 deploy.sh

# 域名（不带协议）
DOMAIN="wzuser.wzagent.cn"

# 项目根目录（宝塔默认路径）
PROJECT_ROOT="/www/wwwroot/maruaudio"

# WebSocket 端口
WS_PORT=8080
WS_INTERNAL_PORT=8081

# PHP-FPM Socket 路径
PHP_FPM_SOCK="/tmp/php-cgi-82.sock"

# SSL 证书路径（宝塔自动申请的路径格式）
SSL_CERT_DIR="/www/server/panel/vhost/cert/${DOMAIN}"

# Nginx 配置目录（宝塔格式）
NGINX_VHOST_DIR="/www/server/panel/vhost/nginx"
NGINX_REWRITE_DIR="/www/server/panel/vhost/rewrite"

# 日志目录
LOG_DIR="/www/wwwlogs"
WS_LOG="/var/log/maruaudio-websocket.log"

# 运行用户
RUN_USER="www"
RUN_GROUP="www"
