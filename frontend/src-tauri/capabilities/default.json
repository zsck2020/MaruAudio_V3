{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCACHE" },
        { "path": "$APPCACHE/**" },
        { "path": "$RESOURCE" },
        { "path": "$RESOURCE/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$HOME/Music/**" },
        { "path": "$HOME/Videos/**" },
        { "path": "$HOME/Pictures/**" },
        { "path": "**/*.wav" },
        { "path": "**/*.mp3" },
        { "path": "**/*.flac" },
        { "path": "**/*.m4a" },
        { "path": "**/*.aac" },
        { "path": "**/*.ogg" },
        { "path": "**/*.mp4" },
        { "path": "**/*.mov" },
        { "path": "**/*.mkv" },
        { "path": "**/*.webm" },
        { "path": "**/*.srt" },
        { "path": "**/*.vtt" },
        { "path": "**/*.ass" },
        { "path": "**/*.json" },
        { "path": "**/MaruAudio*/**" },
        { "path": "**/MaruAudio_V3/**" }
      ],
      "deny": [
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.config/**" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.pypirc" }
      ]
    },
    "dialog:default",
    "dialog:allow-save"
  ]
}